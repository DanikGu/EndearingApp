{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@sveltejs/opencode"
  ],
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest",
        "--headless",
        "--browser",
        "chrome"
      ],
      "enabled": true
    }
  }
}
